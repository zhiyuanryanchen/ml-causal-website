# Website-only repository
# Only website files should be tracked

# Keep these files:
# - docs/ (generated website)
# - _quarto.yml (website config)
# - index.qmd, syllabus.qmd, resources.qmd (source files)
# - styles.css (custom styles)
# - .github/workflows/ (CI/CD)
# - README.md
# - .gitignore

# Ignore everything else
*

# But don't ignore these (website files)
!docs/
!docs/**
!_quarto.yml
!index.qmd
!syllabus.qmd
!resources.qmd
!styles.css
!.github/
!.github/**
!README.md
!.gitignore

# Now re-ignore specific things even in allowed directories
# Quarto cache
.quarto
*.quarto_ipynb

# macOS
.DS_Store

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
