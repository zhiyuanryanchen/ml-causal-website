# ==============================================================================
# .gitignore for Academic Claude Code Projects
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Quarto rendering artifacts
/.quarto/

# Output artifacts — uncomment lines below based on your preference
# *.rds
# output/**/*.rds
Draft/Main_Finance_RD_draft.pdf
.gitignore
Draft/Main_Finance_RD_draft.tex
quality_reports/Main_Finance_RD_draft_proofread_report.md
.gitignore
